      <tr><td>0</td><td>Free registration</td><td>$0</td><td>Required starting point</td></tr>
      <tr><td>1</td><td>Mega Link (Megalink)</td><td>$7 one-time</td><td>Required starting point</td></tr>
      <tr><td>—</td><td>Megalink Traffic Rotator</td><td>~$47/month</td><td>Parallel add-on (traffic)</td></tr>
      <tr><td>—</td><td>OLSP Solo Ads (Traffic Dominators)</td><td>~$90/100 clicks (volume pricing to ~$3,750/5,000 clicks)</td><td>Parallel add-on (traffic)</td></tr>
      <tr><td>—</td><td>OLSP MineeMe</td><td>$27/month promo ($97/month stated regular)</td><td>Parallel add-on (tool)</td></tr>
      <tr><td>2</td><td>Live Profit Builders</td><td>~$49/month or ~$497/year</td><td>Sequential upgrade</td></tr>
      <tr><td>3</td><td>Community Builders</td><td>~$197–199/month or ~$1,997/year</td><td>Sequential upgrade</td></tr>
