  { href: "#lead-magnets", text: "2. Lead Magnets That Attract the Right Subscribers" },
  { href: "#segmentation", text: "3. Segmentation: The Difference That Actually Moves Revenue" },
  { href: "#cadence", text: "4. Cadence and Automation" },
  { href: "#from-list-to-commission", text: "5. Turning a List Into Commissions" },
  { href: "#faq", text: "FAQ" },
