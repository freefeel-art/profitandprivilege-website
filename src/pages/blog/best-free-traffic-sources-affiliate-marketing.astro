const pageDescription = "The free traffic channels worth using before you spend anything on ads — and when a paid tool like a traffic rotator actually becomes worth adding.";

const tocLinks = [
  { href: "#intro", label: "Introduction" },
  { href: "#free-channels", label: "1. The Free Channels Worth Using" },
  { href: "#which-first", label: "2. Which Channel to Start With" },
  { href: "#when-to-add-paid", label: "3. When Free Traffic Stops Being Enough" },
  { href: "#faq", label: "FAQ" },
  { href: "#author", label: "About the Author" },
  { href: "#sources", label: "Sources & References" },
