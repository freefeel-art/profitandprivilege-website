---
export const prerender = true;

import OlspLayout from "../components/olsp-standard/OlspLayout.astro";
import SiteFooter from "../components/olsp-standard/SiteFooter.astro";
import StatusBadge from "../components/mission-control/StatusBadge.astro";
import MetricCard from "../components/mission-control/MetricCard.astro";
import ActivityItem from "../components/mission-control/ActivityItem.astro";
import RunPipeline from "../components/mission-control/RunPipeline.astro";
import PipelineHealth from "../components/mission-control/PipelineHealth.astro";
import PipelineConsole from "../components/mission-control/PipelineConsole.astro";
import PipelineProgress from "../components/mission-control/PipelineProgress.astro";
import ResultsPanel from "../components/mission-control/ResultsPanel.astro";
import OutputLocations from "../components/mission-control/OutputLocations.astro";
import PipelineSummary from "../components/mission-control/PipelineSummary.astro";
import {
  getStageStatus,
  getProductionMetrics,
  getRecentActivity,
  getReports,
  getRepoStatus,
  getQuickLinks,
  getTopUserProblems,
} from "../data/mission-control";

const stages = getStageStatus();
const metrics = getProductionMetrics();
const activity = getRecentActivity();
const reports = getReports();
const repo = getRepoStatus();
const links = getQuickLinks();
const problems = getTopUserProblems();

const tocLinks = [
  { href: "#problems", label: "Today's Top User Problems" },
  { href: "#panel-console", label: "Pipeline Console" },
  { href: "#panel-progress", label: "Pipeline Progress" },
  { href: "#panel-summary", label: "Pipeline Summary" },
  { href: "#panel-results", label: "Results" },
  { href: "#panel-locations", label: "Output Locations" },
  { href: "#pipeline", label: "Pipeline Status" },
  { href: "#metrics", label: "Production Overview" },
  { href: "#activity", label: "Recent Activity" },
  { href: "#reports", label: "Production Reports" },
  { href: "#repo", label: "Repository Status" },
  { href: "#links", label: "Quick Access" },
];
---

<OlspLayout title="Mission Control — OLSP Editorial Dashboard"
  description="Editorial Operating System dashboard for OLSP.PROFITANDPRIVILEGE.COM"
  canonical="https://olsp.profitandprivilege.com/mission-control/"
  tocLinks={tocLinks}>

<section id="problems" class="problems-section">
  <h2>Today's Top User Problems</h2>
  <p class="problems-subtitle">Discovered from Reddit, Google, and community sources. Select a problem to produce an article.</p>

  <div class="problems-list">
  {
    problems.map((p) => (
      <div class="problem-row" data-id={p.id} data-question={p.userQuestion}>
        <div class="problem-left">
          <span class="problem-stars">{'★'.repeat(p.stars)}{'☆'.repeat(5 - p.stars)}</span>
          <div class="problem-info">
            <span class="problem-question">{p.userQuestion}</span>
            <div class="problem-meta">
              <span class="problem-category">{p.category}</span>
              {p.sources.map((s) => <span class="problem-source">{s}</span>)}
            </div>
          </div>
        </div>
        <button type="button" class="problem-produce-btn" data-topic={p.userQuestion} data-id={p.id}>Produce</button>
      </div>
    ))
  }
  </div>
</section>

<PipelineHealth />

<!-- Production Results Card (hidden until pipeline completes) -->
<div id="production-results" class="production-results" style="display:none;">
  <div class="results-header">
    <span class="results-icon">✅</span>
    <h2>Production Complete</h2>
  </div>

  <div class="results-meta">
    <div class="results-meta-item">
      <span class="results-meta-label">Article Title</span>
      <span class="results-meta-value" id="res-title">—</span>
    </div>
    <div class="results-meta-item">
      <span class="results-meta-label">Article Type</span>
      <span class="results-meta-value" id="res-type">Information Article</span>
    </div>
    <div class="results-meta-item">
      <span class="results-meta-label">Pipeline Duration</span>
      <span class="results-meta-value" id="res-duration">—</span>
    </div>
    <div class="results-meta-item">
      <span class="results-meta-label">Status</span>
      <span class="results-meta-value results-status">Published</span>
    </div>
  </div>

  <h3>Generated Assets</h3>
  <div class="results-assets">
    <div class="asset-item"><span class="asset-check">✓</span> Opportunity Brief</div>
    <div class="asset-item"><span class="asset-check">✓</span> Research Brief</div>
    <div class="asset-item"><span class="asset-check">✓</span> Astro Article</div>
    <div class="asset-item"><span class="asset-check">✓</span> QA Report</div>
    <div class="asset-item"><span class="asset-check">✓</span> Publication Report</div>
  </div>

  <h3>Production Timeline</h3>
  <div class="results-timeline">
    <div class="timeline-item"><span class="timeline-check">✓</span> Community Intelligence</div>
    <div class="timeline-item"><span class="timeline-check">✓</span> Editorial Intelligence</div>
    <div class="timeline-item"><span class="timeline-check">✓</span> Opportunity Brief</div>
    <div class="timeline-item"><span class="timeline-check">✓</span> Research Factory</div>
    <div class="timeline-item"><span class="timeline-check">✓</span> Content Production</div>
    <div class="timeline-item"><span class="timeline-check">✓</span> Editorial QA</div>
    <div class="timeline-item"><span class="timeline-check">✓</span> Publishing</div>
  </div>

  <h3>Primary Actions</h3>
  <div class="results-actions">
    <a href="#" class="action-btn" id="action-article">View Article</a>
    <a href="#" class="action-btn" id="action-research">Open Research Brief</a>
    <a href="#" class="action-btn" id="action-qa">View QA Report</a>
    <button type="button" class="action-btn action-btn-primary" id="action-next">Produce Next Article</button>
  </div>
</div>

<!-- Pipeline Console (secondary, collapsed by default after completion) -->
<details id="console-details" class="console-details">
  <summary>Pipeline Console</summary>
  <div class="console-details-inner">
    <PipelineConsole />
  </div>
</details>

<div class="v2-grid">
  <div class="v2-main">
    <PipelineProgress />
    <div class="v2-row">
      <ResultsPanel />
      <OutputLocations />
    </div>
  </div>
  <div class="v2-side">
    <PipelineSummary />
  </div>
</div>

<section id="pipeline">
<h2>Pipeline Status</h2>

<div class="pipeline-flow">
{
  stages.map((stage, i) => (
    <div class="stage-row">
      <div class="stage-col">
        <div class="stage-name">{stage.name}</div>
        <StatusBadge status={stage.status} />
      </div>
      {i < stages.length - 1 && <div class="stage-arrow">↓</div>}
    </div>
  ))
}
</div>
</section>

<section id="metrics">
<h2>Production Overview</h2>

<div class="metric-grid">
  <MetricCard value={metrics.opportunities} label="Opportunities Discovered" sublabel="scored in queue" />
  <MetricCard value={metrics.opportunityBriefs} label="Opportunity Briefs" sublabel="research completed" />
  <MetricCard value={metrics.researchBriefs} label="Research Briefs" sublabel="heavy pipeline" />
  <MetricCard value={metrics.articlesGenerated} label="Articles Generated" sublabel={`${metrics.reviewArticles} reviews · ${metrics.blogArticles} blog`} />
  <MetricCard value={metrics.articlesPublished} label="Articles Published" sublabel="unique slugs" />
  <MetricCard value={metrics.qaReports} label="QA Reports" sublabel="editorial validation" />
  <MetricCard value={metrics.pubReports} label="Publication Reports" sublabel="publish runs" />
</div>
</section>

<section id="activity">
<h2>Recent Activity</h2>

<div class="activity-list">
{
  activity.length > 0
    ? activity.map(item => <ActivityItem hash={item.hash} subject={item.subject} relative={item.relative} />)
    : <p class="empty">No recent activity.</p>
}
</div>
</section>

<section id="reports">
<h2>Production Reports</h2>

<h3>Documentation</h3>
<ul class="report-list">
{
  reports.docs.map(r => (
    <li>
      {r.exists
        ? <a href={r.path} target="_blank" rel="noopener noreferrer">{r.name}</a>
        : <span class="coming-soon">{r.name}</span>
      }
      <span class="report-type">{r.type}</span>
      {!r.exists && <span class="coming-soon-label">Coming Soon</span>}
    </li>
  ))
}
</ul>

<h3>Editorial QA Reports</h3>
<ul class="report-list">
{
  reports.qa.slice(0, 5).map(r => (
    <li>
      {r.exists
        ? <a href={r.path} target="_blank" rel="noopener noreferrer">{r.name}</a>
        : <span class="coming-soon">{r.name}</span>
      }
      <span class="report-type">QA Report</span>
      {!r.exists && <span class="coming-soon-label">Coming Soon</span>}
    </li>
  ))
}
</ul>

<h3>Publication Reports</h3>
<ul class="report-list">
{
  reports.pub.slice(0, 5).map(r => (
    <li>
      {r.exists
        ? <a href={r.path} target="_blank" rel="noopener noreferrer">{r.name}</a>
        : <span class="coming-soon">{r.name}</span>
      }
      <span class="report-type">Publication Report</span>
      {!r.exists && <span class="coming-soon-label">Coming Soon</span>}
    </li>
  ))
}
</ul>
</section>

<section id="repo">
<h2>Repository Status</h2>

<table class="kv-table">
  <tr><td>Branch</td><td><code>{repo.branch}</code></td></tr>
  <tr><td>Last Commit</td><td>{repo.lastCommit}</td></tr>
  <tr><td>Total Commits</td><td>{repo.totalCommits}</td></tr>
  <tr><td>Sprint</td><td>{repo.sprint}</td></tr>
  <tr><td>Phase</td><td>{repo.phase}</td></tr>
  <tr><td>Architecture Freeze</td><td><strong style="color:var(--bad)">ACTIVE</strong></td></tr>
</table>
</section>

<section id="links">
<h2>Quick Access</h2>

<div class="link-grid">
{
  links.map(link => (
    link.exists
      ? <a href={link.path} class="quick-link" target="_blank" rel="noopener noreferrer">
          <strong>{link.label}</strong>
          <span>{link.desc}</span>
        </a>
      : <div class="quick-link disabled">
          <strong>{link.label}</strong>
          <span>{link.desc}</span>
          <span class="coming-soon-badge">Coming Soon</span>
        </div>
  ))
}
</div>
</section>

<SiteFooter />

</OlspLayout>

<script>
  import { pipelineStore, simulatePipeline } from '../scripts/pipeline-runner.js';

  const resultsCard = document.getElementById('production-results');
  const consoleDetails = document.getElementById('console-details');
  const resTitle = document.getElementById('res-title');
  const resDuration = document.getElementById('res-duration');
  const actionNext = document.getElementById('action-next');

  function showResults(topic, duration) {
    if (resTitle) resTitle.textContent = topic;
    if (resDuration) resDuration.textContent = duration;
    if (resultsCard) resultsCard.style.display = 'block';
    if (consoleDetails) consoleDetails.removeAttribute('open');
    resultsCard?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // Listen for pipeline completion
  pipelineStore.subscribe(s => {
    if (s.status === 'completed' && s.startedAt && s.topic) {
      const elapsed = Math.floor((Date.now() - s.startedAt) / 1000);
      const mm = String(Math.floor(elapsed / 60)).padStart(2, '0');
      const ss = String(elapsed % 60).padStart(2, '0');
      showResults(s.topic, `${mm}:${ss}`);
    }
  });

  // Produce Next Article button — scroll back to problems list
  if (actionNext) {
    actionNext.addEventListener('click', () => {
      if (resultsCard) resultsCard.style.display = 'none';
      pipelineStore.reset();
      const problemsEl = document.getElementById('problems');
      if (problemsEl) problemsEl.scrollIntoView({ behavior: 'smooth' });
    });
  }

  document.querySelectorAll('.problem-produce-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const topic = btn.getAttribute('data-topic');
      if (!topic) return;

      // Hide previous results
      if (resultsCard) resultsCard.style.display = 'none';

      // Set up the pipeline for this topic
      pipelineStore.reset();
      pipelineStore.set({
        topic,
        mode: 'produce',
        status: 'queued',
        startedAt: Date.now(),
        operatingMode: 'assisted',
      });

      // Scroll to pipeline progress
      const progressEl = document.getElementById('panel-progress');
      if (progressEl) progressEl.scrollIntoView({ behavior: 'smooth' });

      // Mark this row as active
      document.querySelectorAll('.problem-row').forEach(r => r.classList.remove('active'));
      const row = btn.closest('.problem-row');
      if (row) row.classList.add('active');

      // Update button state
      btn.textContent = 'Running...';
      btn.disabled = true;

      // Run the produce simulation
      simulatePipeline(topic, 'produce').then(() => {
        btn.textContent = 'Done';
        setTimeout(() => {
          btn.textContent = 'Produce';
          btn.disabled = false;
        }, 3000);
      });
    });
  });
</script>

<style is:inline>
  .problems-section { margin-bottom: 2rem; }
  .problems-section h2 { margin: 0 0 .3rem; }
  .problems-subtitle { font-size: .88rem; color: var(--ink-light); margin: 0 0 1rem; }
  .problems-list { display: flex; flex-direction: column; gap: 0; border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; background: var(--bg); }
  .problem-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: .7rem 1rem; border-bottom: 1px solid var(--line);
    transition: background .15s;
  }
  .problem-row:last-child { border-bottom: none; }
  .problem-row:hover { background: var(--bg-soft); }
  .problem-left { display: flex; align-items: center; gap: .8rem; flex: 1; min-width: 0; }
  .problem-stars { font-size: .85rem; color: #f59e0b; letter-spacing: 1px; flex-shrink: 0; white-space: nowrap; }
  .problem-info { display: flex; flex-direction: column; gap: .2rem; min-width: 0; }
  .problem-question { font-size: .9rem; font-weight: 600; color: var(--ink); }
  .problem-meta { display: flex; flex-wrap: wrap; gap: .3rem; }
  .problem-category {
    font-size: .68rem; font-weight: 600; color: var(--accent);
    background: var(--accent-soft); padding: .1rem .45rem; border-radius: 4px;
    text-transform: uppercase; letter-spacing: .04em;
  }
  .problem-source {
    font-size: .65rem; color: var(--ink-light); background: var(--bg-soft);
    padding: .1rem .4rem; border-radius: 4px;
  }
  .problem-produce-btn {
    padding: .4rem 1rem; font-size: .82rem; font-weight: 600;
    border: 1px solid var(--accent); border-radius: var(--radius);
    background: var(--accent); color: #fff; cursor: pointer;
    white-space: nowrap; flex-shrink: 0; transition: opacity .15s;
  }
  .problem-produce-btn:hover { opacity: .85; }
  .problem-row.active { background: var(--accent-soft); border-color: var(--accent); }
  .problem-row.active .problem-question { color: var(--accent); }

  /* Production Results Card */
  .production-results {
    border: 2px solid var(--good);
    border-radius: var(--radius);
    padding: 1.5rem;
    background: var(--bg);
    margin-bottom: 1.5rem;
  }
  .results-header { display: flex; align-items: center; gap: .6rem; margin-bottom: 1rem; }
  .results-header h2 { margin: 0; color: var(--good); }
  .results-icon { font-size: 1.4rem; }
  .results-meta { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: .6rem; margin-bottom: 1.2rem; }
  .results-meta-item {
    display: flex; flex-direction: column; padding: .6rem .8rem;
    border: 1px solid var(--line); border-radius: var(--radius); background: var(--bg); gap: .15rem;
  }
  .results-meta-label { font-size: .72rem; color: var(--ink-light); text-transform: uppercase; letter-spacing: .04em; font-weight: 600; }
  .results-meta-value { font-size: .9rem; color: var(--ink); font-weight: 600; }
  .results-status { color: var(--good); }
  .production-results h3 { font-size: .9rem; margin: 1rem 0 .5rem; color: var(--ink); }
  .results-assets { display: flex; flex-direction: column; gap: .3rem; margin-bottom: .5rem; }
  .asset-item { display: flex; align-items: center; gap: .5rem; font-size: .88rem; color: var(--ink); }
  .asset-check { color: var(--good); font-weight: 700; }
  .results-timeline { display: flex; flex-direction: column; gap: .3rem; margin-bottom: .5rem; }
  .timeline-item { display: flex; align-items: center; gap: .5rem; font-size: .88rem; color: var(--ink); }
  .timeline-check { color: var(--good); font-weight: 700; }
  .results-actions { display: flex; flex-wrap: wrap; gap: .5rem; }
  .action-btn {
    padding: .5rem 1.2rem; font-size: .85rem; font-weight: 600;
    border: 1px solid var(--line); border-radius: var(--radius);
    background: var(--bg); color: var(--ink); cursor: pointer;
    text-decoration: none; transition: border-color .15s, background .15s;
  }
  .action-btn:hover { border-color: var(--accent); background: var(--accent-soft); }
  .action-btn-primary { background: var(--accent); color: #fff; border-color: var(--accent); }
  .action-btn-primary:hover { opacity: .85; background: var(--accent); }

  /* Console Details (collapsed by default after completion) */
  .console-details { margin-bottom: 1.5rem; }
  .console-details summary {
    font-size: .95rem; font-weight: 600; color: var(--ink-light); cursor: pointer;
    padding: .5rem 0; list-style: none;
  }
  .console-details summary::before { content: '▶ '; font-size: .75rem; }
  .console-details[open] summary::before { content: '▼ '; }
  .console-details-inner { margin-top: .5rem; }

  .pipeline-flow { max-width: 440px; }
  .stage-row { display: flex; flex-direction: column; align-items: flex-start; }
  .stage-col { display: flex; align-items: center; gap: 1rem; width: 100%; padding: .7rem 0; }
  .stage-name { font-size: .95rem; font-weight: 600; color: var(--ink); min-width: 200px; }
  .stage-arrow { color: var(--ink-light); font-size: .8rem; padding-left: .3rem; opacity: .5; margin: -.2rem 0; }

  .metric-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(170px, 1fr)); gap: .8rem; }

  .activity-list { border: 1px solid var(--line); border-radius: var(--radius); padding: 0 1rem; background: var(--bg); }
  .empty { color: var(--ink-light); font-size: .9rem; padding: .8rem 0; }

  .report-list { list-style: none; padding: 0; margin: 0 0 1.5rem; }
  .report-list li { padding: .35rem 0; font-size: .9rem; }
  .report-list a { color: var(--accent); }
  .report-list a:hover { text-decoration: underline; }
  .report-type { font-size: .72rem; color: var(--ink-light); background: var(--bg-soft); padding: .1rem .5rem; border-radius: 4px; margin-left: .5rem; text-transform: uppercase; letter-spacing: .04em; }

  .kv-table { width: 100%; max-width: 500px; }
  .kv-table td { padding: .5rem .7rem; border-bottom: 1px solid var(--line); font-size: .9rem; }
  .kv-table td:first-child { color: var(--ink-light); font-weight: 600; width: 180px; }
  .kv-table code { font-size: .85rem; background: var(--bg-soft); padding: .1rem .4rem; border-radius: 4px; }

  .link-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: .7rem; }
  .quick-link {
    display: flex; flex-direction: column;
    padding: .9rem 1rem;
    border: 1px solid var(--line); border-radius: var(--radius);
    background: var(--bg);
    text-decoration: none;
    transition: border-color .15s;
  }
  .quick-link:hover { border-color: var(--accent); text-decoration: none; }
  .quick-link strong { font-size: .88rem; color: var(--ink); margin-bottom: .15rem; }
  .quick-link span { font-size: .78rem; color: var(--ink-light); }
  .quick-link.disabled { opacity: .55; cursor: default; }
  .quick-link.disabled:hover { border-color: var(--line); }
  .coming-soon-badge { font-size: .68rem; color: var(--ink-light); background: var(--bg-soft); padding: .1rem .5rem; border-radius: 4px; text-transform: uppercase; letter-spacing: .04em; margin-top: .25rem; align-self: flex-start; }
  .coming-soon { color: var(--ink-light); }
  .coming-soon-label { font-size: .68rem; color: var(--ink-light); background: var(--bg-soft); padding: .1rem .5rem; border-radius: 4px; text-transform: uppercase; letter-spacing: .04em; margin-left: .4rem; }

  .v2-grid { display: grid; grid-template-columns: 1fr 280px; gap: 1.2rem; margin-bottom: 2rem; align-items: start; }
  .v2-main { display: flex; flex-direction: column; gap: 1.2rem; }
  .v2-side { display: flex; flex-direction: column; gap: 1.2rem; }
  .v2-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; }
</style>
