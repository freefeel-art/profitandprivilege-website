<script is:inline>
(function(){
  // Mobile TOC toggle
  var btn = document.getElementById('tocToggle');
  var wrap = document.getElementById('tocWrap');
  if(btn && wrap){
    btn.addEventListener('click', function(){
      wrap.classList.toggle('open');
    });
  }

  // Scroll-spy
  var nav = document.getElementById('tocNav');
  if(nav){
    var links = nav.querySelectorAll('a');
    var sections = document.querySelectorAll('main section');
    var linkMap = {};
    for(var i = 0; i < links.length; i++){
      var href = links[i].getAttribute('href');
      if(href && href.charAt(0) === '#'){
        linkMap[href.substring(1)] = links[i];
      }
    }
    var observer = new IntersectionObserver(function(entries){
      for(var j = 0; j < entries.length; j++){
        if(entries[j].isIntersecting){
          for(var key in linkMap){
            linkMap[key].classList.remove('active');
          }
          var id = entries[j].target.getAttribute('id');
          if(linkMap[id]){
            linkMap[id].classList.add('active');
          }
        }
      }
    }, {rootMargin: '-20% 0px -70% 0px'});
    for(var k = 0; k < sections.length; k++){
      observer.observe(sections[k]);
    }

    // Close TOC on link click (mobile)
    for(var m = 0; m < links.length; m++){
      links[m].addEventListener('click', function(){
        if(window.innerWidth <= 900 && wrap){
          wrap.classList.remove('open');
        }
      });
    }
  }
})();
</script>

