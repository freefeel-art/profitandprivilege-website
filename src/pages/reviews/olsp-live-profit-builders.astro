  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      const link = linkMap[entry.target.id];
      if (!link) return;
      if (entry.isIntersecting) {
        tocLinks.forEach(l => l.classList.remove('active'));
        link.classList.add('active');
      }
    });
  }, { rootMargin: '-20% 0px -70% 0px' });

  sections.forEach(s => observer.observe(s));

  // Close mobile TOC after clicking a link
  tocLinks.forEach(link => {
    link.addEventListener('click', () => {
      if (window.innerWidth <= 900) tocWrap.classList.remove('open');
    });
  });

  // Quick self-check quiz
  function evaluateQuiz(){
    const q1 = document.querySelector('input[name="q1"]:checked');
    const q2 = document.querySelector('input[name="q2"]:checked');
    const q3 = document.querySelector('input[name="q3"]:checked');
    const result = document.getElementById('quiz-result');

    if(!q1 || !q2 || !q3){
      result.style.display = 'block';
      result.textContent = 'Please answer all three questions first.';
      return;
    }

    const score = parseInt(q1.value) + parseInt(q2.value) + parseInt(q3.value);
    let message = '';
    if(score >= 5){
      message = "Based on your answers, you appear to have the prerequisites for Live Profit Builders — an existing traffic source, a workable event promotion schedule, and validated entry-level results. Verify current pricing and terms directly with OLSP before committing, and treat all income projections as vendor claims rather than guaranteed outcomes.";
    } else if(score >= 3){
      message = "Your answers suggest a mixed fit. At least one key prerequisite isn't fully in place. Review the 'Skip If' section above before committing to a subscription, and consider whether building that missing element at the Megalink level first would set you up better for LPB.";
    } else {
      message = "Based on your answers, the core prerequisites for Live Profit Builders likely aren't met yet. Start with the free OLSP account or Megalink level, build a consistent traffic source and promotional habit, and reassess once you're generating regular commissions at that level.";
    }
    result.style.display = 'block';
    result.textContent = message;
  }
</script>

</body>
</html>
