<script is:inline>
  // Mobile TOC toggle
  const tocToggle = document.getElementById('tocToggle');
  const tocWrap = document.getElementById('tocWrap');
  if (tocToggle) {
    tocToggle.addEventListener('click', () => {
      tocWrap.classList.toggle('open');
    });
  }

  // Scroll-spy active link highlighting
  const sections = document.querySelectorAll('main section');
  const tocLinks = document.querySelectorAll('#tocNav a');
  const linkMap = {};
  tocLinks.forEach(link => { linkMap[link.getAttribute('href').slice(1)] = link; });

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      const link = linkMap[entry.target.id];
      if (!link) return;
      if (entry.isIntersecting) {
        tocLinks.forEach(l => l.classList.remove('active'));
        link.classList.add('active');
      }
    });
  }, { rootMargin: '-20% 0px -70% 0px' });

  sections.forEach(s => observer.observe(s));

  // Close mobile TOC after clicking a link
  tocLinks.forEach(link => {
    link.addEventListener('click', () => {
      if (window.innerWidth <= 900) tocWrap.classList.remove('open');
    });
  });

  // Quick self-check quiz
  function evaluateQuiz(){
    const q1 = document.querySelector('input[name="q1"]:checked');
    const q2 = document.querySelector('input[name="q2"]:checked');
    const q3 = document.querySelector('input[name="q3"]:checked');
    const result = document.getElementById('quiz-result');

    if(!q1 || !q2 || !q3){
      result.style.display = 'block';
      result.textContent = 'Please answer all three questions first.';
      return;
    }

    const score = parseInt(q1.value) + parseInt(q2.value) + parseInt(q3.value);
    let message = '';
    if(score >= 5){
      message = "Based on your answers, Chatbase is a strong fit for your business. You need model flexibility and AI Actions, and you already have a helpdesk for live chat handoff. The Standard plan at $120/month likely offers the best value. Start with the free plan to validate accuracy, then upgrade.";
    } else if(score >= 3){
      message = "Your answers suggest a mixed fit. Chatbase could work if your need for model flexibility or AI Actions justifies the lack of built-in live chat. Consider starting with the free plan and upgrading to Hobby ($32/month) if the AI handles your questions well and you do not miss the live chat feature.";
    } else {
      message = "Based on your answers, Chatbase may not be the right investment for your current workflow. Consider Tidio if you need built-in live chat, or FastBots.ai for simple FAQ automation on a budget. Re-evaluate Chatbase if your needs evolve toward AI model flexibility or task automation.";
    }
    result.style.display = 'block';
    result.textContent = message;
  }
</script>

