---
export const prerender = true;

interface TocLink {
  href: string;
  label: string;
}

interface Props {
  title: string;
  description: string;
  canonical: string;
  tocLinks: TocLink[];
  ogImage?: string;
  datePublished?: string;
  dateModified?: string;
  articleType?: "Article" | "Review" | "BlogPosting";
  productName?: string;
}

const { title, description, canonical, tocLinks, ogImage, datePublished, dateModified, articleType, productName } = Astro.props;

const siteUrl = "https://olsp.profitandprivilege.com";
const defaultAuthor = { name: "Jarmo Halonen", url: `${siteUrl}/authors/jarmo-halonen` };
const defaultPublisher = { name: "Profit and Privilege", url: siteUrl };
const resolvedDateModified = dateModified || datePublished;

const schemaOrg = {
  "@context": "https://schema.org",
  "@graph": [] as Record<string, unknown>[],
};

if (articleType === "Review" && productName) {
  const review: Record<string, unknown> = {
    "@type": "Review",
    itemReviewed: { "@type": "Product", name: productName },
    author: { "@type": "Person", ...defaultAuthor },
    url: canonical,
    publisher: { "@type": "Organization", ...defaultPublisher },
  };
  if (datePublished) review.datePublished = datePublished;
  if (resolvedDateModified) review.dateModified = resolvedDateModified;
  schemaOrg["@graph"].push(review);
} else {
  const article: Record<string, unknown> = {
    "@type": articleType === "BlogPosting" ? "BlogPosting" : "Article",
    headline: title,
    description,
    url: canonical,
    author: { "@type": "Person", ...defaultAuthor },
    publisher: { "@type": "Organization", ...defaultPublisher },
    mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
  };
  if (datePublished) article.datePublished = datePublished;
  if (resolvedDateModified) article.dateModified = resolvedDateModified;
  schemaOrg["@graph"].push(article);
}

schemaOrg["@graph"].push({ "@type": "Organization", ...defaultPublisher });
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<meta name="description" content={description}>
<link rel="canonical" href={canonical} />
<meta name="robots" content="index, follow" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:type" content="article" />
<meta property="og:site_name" content="Profit and Privilege" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{ogImage && <meta property="og:image" content={ogImage} />}
{ogImage && <meta name="twitter:image" content={ogImage} />}
<script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
<style is:global>
  :root{
    --ink:#1e293b;
    --ink-light:#475569;
    --bg:#ffffff;
    --bg-soft:#f8fafc;
    --line:#e2e8f0;
    --accent:#2563eb;
    --accent-soft:#eff6ff;
    --warn:#92400e;
    --warn-bg:#fef3c7;
    --warn-border:#fcd34d;
    --good:#166534;
    --good-bg:#f0fdf4;
    --bad:#991b1b;
    --bad-bg:#fef2f2;
    --radius:10px;
  }
  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    margin:0;
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
    color:var(--ink);
    background:var(--bg);
    line-height:1.65;
    font-size:17px;
  }
  h1,h2,h3{line-height:1.25; color:var(--ink);}
  h1{font-size:1.9rem; margin:0 0 .5rem;}
  h2{font-size:1.5rem; margin-top:0; border-bottom:3px solid var(--accent-soft); padding-bottom:.4rem;}
  h3{font-size:1.15rem; color:var(--accent);}
  p{margin:0 0 1rem;}
  a{color:var(--accent); text-decoration:none;}
  a:hover{text-decoration:underline;}
  ul,ol{margin:0 0 1rem; padding-left:1.3rem;}
  li{margin-bottom:.4rem;}

  .layout{
    display:grid;
    grid-template-columns:280px 1fr;
    max-width:1280px;
    margin:0 auto;
  }
  .toc-wrap{
    position:sticky;
    top:0;
    align-self:start;
    height:100vh;
    overflow-y:auto;
    border-right:1px solid var(--line);
    background:var(--bg-soft);
    padding:1.5rem 1rem;
  }
  .toc-wrap h4{
    font-size:.75rem;
    letter-spacing:.08em;
    text-transform:uppercase;
    color:var(--ink-light);
    margin:0 0 .75rem;
  }
  .toc-wrap nav a{
    display:block;
    font-size:.9rem;
    color:var(--ink-light);
    padding:.45rem .6rem;
    border-radius:6px;
    margin-bottom:.15rem;
  }
  .toc-wrap nav a:hover{background:var(--accent-soft); text-decoration:none; color:var(--accent);}
  .toc-wrap nav a.active{background:var(--accent); color:#fff; font-weight:600;}

  main{padding:2.5rem 3rem 5rem; max-width:880px;}
  section{margin-bottom:3rem; scroll-margin-top:1rem;}

  .hero-tag{
    display:inline-block;
    background:var(--accent-soft);
    color:var(--accent);
    font-size:.8rem;
    font-weight:600;
    padding:.3rem .7rem;
    border-radius:99px;
    margin-bottom:.8rem;
  }
  .verdict-box{
    background:var(--bg-soft);
    border:1px solid var(--line);
    border-left:5px solid var(--accent);
    border-radius:var(--radius);
    padding:1.2rem 1.4rem;
    margin:1.2rem 0 1.5rem;
  }
  .verdict-box p{margin-bottom:.4rem;}
  .verdict-box p:last-child{margin-bottom:0;}

  .callout{
    border-radius:var(--radius);
    padding:1rem 1.2rem;
    margin:1.2rem 0;
    border:1px solid var(--line);
  }
  .callout.warn{background:var(--warn-bg); border-color:var(--warn-border); color:var(--warn);}
  .callout.warn strong{color:#78350f;}
  .callout.info{background:var(--accent-soft); border-color:#bfdbfe; color:#1e3a5f;}
  .callout.info strong{color:#1e3a8a;}

  .methodology{
    background:#fff;
    border:1px dashed #94a3b8;
    border-radius:var(--radius);
    padding:1rem 1.2rem;
    font-size:.95rem;
    color:var(--ink-light);
  }

  table{
    width:100%;
    border-collapse:collapse;
    margin:1rem 0 1.5rem;
    font-size:.93rem;
  }
  th,td{
    text-align:left;
    padding:.6rem .7rem;
    border-bottom:1px solid var(--line);
    vertical-align:top;
  }
  th{background:var(--bg-soft); font-size:.78rem; text-transform:uppercase; letter-spacing:.04em; color:var(--ink-light);}
  .table-scroll{overflow-x:auto; -webkit-overflow-scrolling:touch;}

  .two-col{display:grid; grid-template-columns:1fr 1fr; gap:1.2rem;}
  .pc-card{border-radius:var(--radius); padding:1.1rem 1.2rem; border:1px solid var(--line);}
  .pc-card.good{background:var(--good-bg); border-color:#bbf7d0;}
  .pc-card.bad{background:var(--bad-bg); border-color:#fecaca;}
  .pc-card h3{margin-top:0;}
  .pc-card.good h3{color:var(--good);}
  .pc-card.bad h3{color:var(--bad);}
  .pc-card ul{margin-bottom:0; padding-left:1.1rem;}

  .score-row{display:flex; align-items:center; gap:.8rem; margin-bottom:.7rem;}
  .score-label{flex:0 0 190px; font-size:.9rem; color:var(--ink-light);}
  .score-track{flex:1; height:10px; background:var(--line); border-radius:99px; overflow:hidden;}
  .score-fill{height:100%; background:var(--accent); border-radius:99px;}
  .score-num{flex:0 0 36px; text-align:right; font-weight:700; font-size:.9rem;}

  .quiz-box{
    background:var(--bg-soft);
    border:1px solid var(--line);
    border-radius:var(--radius);
    padding:1.3rem 1.4rem;
  }
  .quiz-box fieldset{border:none; margin:0 0 1rem; padding:0;}
  .quiz-box legend{font-weight:600; margin-bottom:.5rem; font-size:.95rem;}
  .quiz-box label{display:block; font-size:.92rem; margin-bottom:.35rem; cursor:pointer;}
  .quiz-box button{
    background:var(--accent);
    color:#fff;
    border:none;
    padding:.6rem 1.2rem;
    border-radius:8px;
    font-size:.95rem;
    cursor:pointer;
  }
  .quiz-box button:hover{background:#1d4ed8;}
  #quiz-result{
    margin-top:1rem;
    padding:.9rem 1rem;
    border-radius:8px;
    background:#fff;
    border:1px solid var(--line);
    font-size:.93rem;
    display:none;
  }

  .video-frame{
    position:relative;
    width:100%;
    padding-top:56.25%;
    background:#000;
    border-radius:var(--radius);
    overflow:hidden;
    margin-bottom:.6rem;
  }
  .video-frame iframe{position:absolute; top:0; left:0; width:100%; height:100%; border:0;}
  .video-caption{font-size:.85rem; color:var(--ink-light); margin-top:0; margin-bottom:1.6rem;}

  details{
    border:1px solid var(--line);
    border-radius:8px;
    margin-bottom:.6rem;
    padding:.7rem 1rem;
  }
  summary{font-weight:600; cursor:pointer; font-size:.97rem;}
  details p{margin-top:.6rem; margin-bottom:0; color:var(--ink-light); font-size:.95rem;}

  figure{margin:1rem 0 1.6rem;}
  figure svg{width:100%; max-width:640px; display:block; margin:0 auto;}
  figcaption{text-align:center; font-size:.82rem; color:var(--ink-light); margin-top:.5rem;}

  .author-box{
    display:flex;
    align-items:flex-start;
    gap:1.2rem;
    border:1px solid var(--line);
    border-radius:var(--radius);
    padding:1.2rem 1.4rem;
    background:var(--bg-soft);
  }
  .author-box img{width:72px; height:72px; border-radius:50%; flex-shrink:0; object-fit:cover;}
  .author-box-info{flex:1;}
  .author-box-info h4{margin:0 0 .15rem; font-size:1rem; color:var(--ink);}
  .author-box-info .author-role{font-size:.85rem; color:var(--ink-light); margin:0 0 .55rem; display:block;}
  .author-box-info p{font-size:.9rem; color:var(--ink-light); margin:0 0 .4rem;}
  .author-box-info p:last-child{margin:0;}

  .mobile-toc-btn{display:none;}

  .goldmaster-quote{
    display:block;
    text-align:center;
    margin:3rem 0;
    font-size:1.15rem;
    font-weight:600;
    font-style:italic;
    line-height:1.6;
    color:var(--ink);
    text-decoration:none;
  }
  .goldmaster-quote:hover{color:var(--accent); text-decoration:none;}

  .cta-card{
    border-radius:var(--radius);
    padding:1.1rem 1.3rem;
    border:1px solid var(--line);
    background:var(--accent-soft);
    border-left:4px solid var(--accent);
    margin:3rem 0;
  }
  .cta-card h3{font-size:1.05rem; margin:0 0 .3rem; color:var(--ink);}
  .cta-card p{font-size:.92rem; margin:0 0 .8rem; color:var(--ink-light); line-height:1.55;}
  .cta-card .cta-btn{font-size:.88rem; padding:.45rem 1.1rem;}
  .cta-card .cta-btn::after{content:" →";}

  .cta-btn{
    display:inline-block;
    background:var(--accent);
    color:#fff;
    font-weight:600;
    border-radius:8px;
  }
  .cta-btn:hover{background:#1d4ed8; text-decoration:none; color:#fff;}

  .pill-list{display:flex; flex-wrap:wrap; gap:.45rem; margin:0 0 1rem; padding:0; list-style:none;}
  .pill-list li{margin:0;}
  .pill-list a{
    display:inline-block;
    font-size:.78rem;
    background:var(--bg-soft);
    color:var(--ink-light);
    border:1px solid var(--line);
    border-radius:99px;
    padding:.25rem .7rem;
    white-space:nowrap;
  }
  .pill-list a:hover{background:var(--accent-soft); color:var(--accent); border-color:var(--accent); text-decoration:none;}

  .site-footer{
    border-top:1px solid var(--line);
    padding:1.2rem 0 0;
    margin-top:2rem;
    font-size:.8rem;
    color:var(--ink-light);
    display:flex;
    justify-content:space-between;
    align-items:center;
    flex-wrap:wrap;
    gap:.4rem;
  }
  .site-footer a{color:var(--ink-light);}
  .site-footer a:hover{color:var(--accent); text-decoration:underline;}

  @media (max-width:900px){
    .layout{grid-template-columns:1fr;}
    .toc-wrap{
      position:sticky; top:0; height:auto; max-height:0; overflow:hidden;
      transition:max-height .25s ease;
      border-right:none; border-bottom:1px solid var(--line);
      z-index:50;
    }
    .toc-wrap.open{max-height:70vh; overflow-y:auto;}
    .mobile-toc-btn{
      display:block; position:sticky; top:0; z-index:60;
      width:100%; text-align:left; background:var(--ink); color:#fff;
      border:none; padding:.9rem 1.2rem; font-size:.95rem; font-weight:600;
    }
    main{padding:1.5rem 1.2rem 3rem;}
    .two-col{grid-template-columns:1fr;}
    .score-label{flex:0 0 130px; font-size:.82rem;}
  }
</style>
</head>
<body>

<div class="layout">

  <button class="mobile-toc-btn" id="tocToggle">☰ Table of Contents</button>
  <aside class="toc-wrap" id="tocWrap">
    <h4>On This Page</h4>
    <nav id="tocNav">
      {tocLinks.map(link => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>
  </aside>

  <main>
    <slot />
  </main>

</div>

<script is:inline>
  const tocToggle = document.getElementById('tocToggle');
  const tocWrap = document.getElementById('tocWrap');
  if (tocToggle) {
    tocToggle.addEventListener('click', () => {
      tocWrap.classList.toggle('open');
    });
  }

  const sections = document.querySelectorAll('main section');
  const tocLinks = document.querySelectorAll('#tocNav a');
  const linkMap = {};
  tocLinks.forEach(link => { linkMap[link.getAttribute('href').slice(1)] = link; });

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      const link = linkMap[entry.target.id];
      if (!link) return;
      if (entry.isIntersecting) {
        tocLinks.forEach(l => l.classList.remove('active'));
        link.classList.add('active');
      }
    });
  }, { rootMargin: '-20% 0px -70% 0px' });

  sections.forEach(s => observer.observe(s));

  tocLinks.forEach(link => {
    link.addEventListener('click', () => {
      if (window.innerWidth <= 900) tocWrap.classList.remove('open');
    });
  });

  function evaluateQuiz(){
    const q1 = document.querySelector('input[name="q1"]:checked');
    const q2 = document.querySelector('input[name="q2"]:checked');
    const q3 = document.querySelector('input[name="q3"]:checked');
    const result = document.getElementById('quiz-result');

    if(!q1 || !q2 || !q3){
      result.style.display = 'block';
      result.textContent = 'Please answer all three questions first.';
      return;
    }

    const score = parseInt(q1.value) + parseInt(q2.value) + parseInt(q3.value);
    let message = '';
    if(score >= 5){
      message = "Based on your answers, this product appears to align with your situation. Review the detailed sections above for more context.";
    } else if(score >= 3){
      message = "Your answers suggest a mixed fit. At least one important condition isn't fully in place — review the 'Skip If' section before committing.";
    } else {
      message = "Based on your answers, this product likely isn't the right fit for your current situation. Consider alternative approaches first.";
    }
    result.style.display = 'block';
    result.textContent = message;
  }
</script>

</body>
</html>
